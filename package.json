{
  "name": "liburin",
  "version": "1.0.0",
  "description": "API Open Source Hari Libur dan Cuti Nasional di Indonesia",
  "main": "src/index.ts",
  "scripts": {
    "build:css": "tailwindcss -i ./src/styles/input.css -o ./public/styles.css",
    "dev:css": "tailwindcss -i ./src/styles/input.css -o ./public/styles.css --watch",
    "dev": "bun run build:css && bun run --watch src/index.ts",
    "start": "bun run src/index.ts",
    "scrape": "bun run src/scraper.ts"
  },
  "dependencies": {
    "cheerio": "^1.0.0"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "tailwindcss": "^3.4.3"
  }
}
